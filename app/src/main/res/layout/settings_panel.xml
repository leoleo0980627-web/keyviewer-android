<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:elevation="8dp"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="按键设置"
            android:textSize="18sp"
            android:textColor="#333"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- 按键绑定 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="绑定按键"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/keyBindBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="未绑定"
            android:textSize="16sp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFF"
            android:layout_marginBottom="20dp" />

        <!-- 映射按键 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="映射按键"
            android:textSize="16sp"
            android:textColor="#333"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <Switch
            android:id="@+id/mappingEnabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="启用按键映射"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/mappingSettingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/mappingBindBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="点击设置映射按键"
                android:textSize="14sp"
                android:backgroundTint="#FF9800"
                android:textColor="#FFF"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- 显示文字 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="显示文字"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/labelInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text=""
            android:hint="留空则显示按键名"
            android:textSize="14sp"
            android:padding="8dp"
            android:background="#FFF"
            android:layout_marginBottom="20dp"
            android:imeOptions="actionDone"
            android:inputType="text" />

        <!-- 文字大小 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="文字大小 (sp)"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/textSizeInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="number"
            android:text="14"
            android:textSize="14sp"
            android:padding="8dp"
            android:background="#FFF"
            android:layout_marginBottom="20dp"
            android:imeOptions="actionDone" />

        <!-- 文字颜色 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="文字颜色"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/textColorInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="#FFFFFF"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="#FFF"
                android:layout_marginEnd="8dp"
                android:imeOptions="actionDone"
                android:inputType="text" />

            <View
                android:id="@+id/textColorPreview"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#FFFFFF" />

        </LinearLayout>

        <!-- 显示按键次数 -->
        <Switch
            android:id="@+id/showCountSwitch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="显示按键次数"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <!-- 尺寸设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="尺寸"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="48dp"
                android:text="W"
                android:textSize="14sp"
                android:textColor="#666"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/widthInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:inputType="number"
                android:text="50"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="#FFF"
                android:layout_marginEnd="8dp"
                android:imeOptions="actionDone" />

            <TextView
                android:layout_width="24dp"
                android:layout_height="48dp"
                android:text="H"
                android:textSize="14sp"
                android:textColor="#666"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/heightInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:inputType="number"
                android:text="50"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="#FFF"
                android:imeOptions="actionDone" />

        </LinearLayout>

        <!-- 圆角半径 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="圆角半径"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/cornerRadiusInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:inputType="number"
                android:text="8"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="#FFF"
                android:imeOptions="actionDone" />

            <TextView
                android:layout_width="40dp"
                android:layout_height="48dp"
                android:text="dp"
                android:textSize="14sp"
                android:textColor="#666"
                android:gravity="center" />

        </LinearLayout>

        <!-- 边框宽度 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="边框宽度"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/borderWidthInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="number"
            android:text="5"
            android:textSize="14sp"
            android:padding="8dp"
            android:background="#FFF"
            android:layout_marginBottom="20dp"
            android:imeOptions="actionDone" />

        <!-- 填充颜色 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="填充颜色"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/fillColorInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="#999999"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="#FFF"
                android:layout_marginEnd="8dp"
                android:imeOptions="actionDone"
                android:inputType="text" />

            <View
                android:id="@+id/fillColorPreview"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#999999" />

        </LinearLayout>

        <!-- 边框颜色 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="边框颜色"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/borderColorInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="#666666"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="#FFF"
                android:layout_marginEnd="8dp"
                android:imeOptions="actionDone"
                android:inputType="text" />

            <View
                android:id="@+id/borderColorPreview"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#666666" />

        </LinearLayout>

        <!-- 键雨效果 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="键雨效果"
            android:textSize="16sp"
            android:textColor="#333"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <Switch
            android:id="@+id/rainEnabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="启用键雨"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/rainSettingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X 偏移"
                android:textSize="14sp"
                android:textColor="#666"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/rainOffsetXInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="numberSigned"
                android:text="0"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="#FFF"
                android:layout_marginBottom="12dp"
                android:imeOptions="actionDone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Y 偏移"
                android:textSize="14sp"
                android:textColor="#666"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/rainOffsetYInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="numberSigned"
                android:text="0"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="#FFF"
                android:layout_marginBottom="12dp"
                android:imeOptions="actionDone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="宽度 (%)"
                android:textSize="14sp"
                android:textColor="#666"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/rainWidthInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:text="100"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="#FFF"
                android:layout_marginBottom="12dp"
                android:imeOptions="actionDone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="键雨颜色"
                android:textSize="14sp"
                android:textColor="#666"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/rainColorInput"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="#FFFFFF"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="#FFF"
                    android:layout_marginEnd="8dp"
                    android:imeOptions="actionDone"
                    android:inputType="text" />

                <View
                    android:id="@+id/rainColorPreview"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="#FFFFFF" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="速度"
                android:textSize="14sp"
                android:textColor="#666"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/rainSpeedInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:text="5"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="#FFF"
                android:imeOptions="actionDone" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>